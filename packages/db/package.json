{
  "name": "@englishlearn/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./queries/*": "./src/queries/*.ts",
    "./generated/*": "./src/generated/*"

  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "push": "prisma db push",
    "studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf src/generated .turbo node_modules"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "catalog:",
    "bcryptjs": "catalog:",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@englishlearn/config": "workspace:*",
    "@types/bcryptjs": "catalog:",
    "@types/node": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
