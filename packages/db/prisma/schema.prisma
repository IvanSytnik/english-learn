// EnglishLearn database schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Auth (Auth.js v5 / NextAuth)
// ─────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  TUTOR
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          UserRole  @default(STUDENT)
  locale        String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  profile            StudentProfile?
  diagnosticAttempts DiagnosticAttempt[]
  vocabAttempts      VocabAttempt[]
  grammarAttempts    GrammarAttempt[]
  listeningAttempts  ListeningAttempt[]
  skillLevels        SkillLevel[]
  conceptMasteries ConceptMastery[]
  itemReviewStates ItemReviewState[]
  learnerEvents LearnerEvent[]


  // Content authorship
  createdVocabExercises      VocabExercise[]     @relation("VocabCreatedBy")
  reviewedVocabExercises     VocabExercise[]     @relation("VocabReviewedBy")
  createdGrammarExercises    GrammarExercise[]   @relation("GrammarCreatedBy")
  reviewedGrammarExercises   GrammarExercise[]   @relation("GrammarReviewedBy")
  createdListeningExercises  ListeningExercise[] @relation("ListeningCreatedBy")
  reviewedListeningExercises ListeningExercise[] @relation("ListeningReviewedBy")
  createdDiagnosticItems     DiagnosticItem[]    @relation("DiagnosticCreatedBy")
  reviewedDiagnosticItems    DiagnosticItem[]    @relation("DiagnosticReviewedBy")

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Student profile
// ─────────────────────────────────────────────────────────────

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum LearningGoal {
  WORK
  IMMIGRATION
  TRAVEL
  EXAM
  GENERAL
}

model StudentProfile {
  id                String        @id @default(cuid())
  userId            String        @unique
  nativeLanguage    String
  selfReportedLevel CefrLevel?
  assessedLevel     CefrLevel?
  goal              LearningGoal?
  dailyGoalMin      Int           @default(15)
  streakDays        Int           @default(0)
  lastActiveAt      DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────
// Content lifecycle
// ─────────────────────────────────────────────────────────────

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum ItemKind {
  VOCAB_WORD
  GRAMMAR_PATTERN
  COLLOCATION
  IDIOM
}

/// FSRS card lifecycle state. Mirrors ts-fsrs `State` (New/Learning/Review/Relearning).
enum FsrsCardStatus {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum ExerciseSource {
  CURATED
  AI_GENERATED
}

// ─────────────────────────────────────────────────────────────
// Skills taxonomy
// ─────────────────────────────────────────────────────────────

enum SkillCategory {
  GRAMMAR
  VOCABULARY
  LISTENING
  READING
  SPEAKING
  WRITING
  PRONUNCIATION
}

model SkillTag {
  id          String        @id @default(cuid())
  slug        String        @unique
  category    SkillCategory
  cefrLevel   CefrLevel
  title       String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vocabExercises     VocabExercise[]
  grammarExercises   GrammarExercise[]
  listeningExercises ListeningExercise[]
  skillLevels        SkillLevel[]
  diagnosticItems    DiagnosticItem[]

  @@index([category, cefrLevel])
}

model SkillLevel {
  id         String    @id @default(cuid())
  userId     String
  skillTagId String
  mastery    Float     @default(0)
  attempts   Int       @default(0)
  lastSeenAt DateTime?
  updatedAt  DateTime  @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@unique([userId, skillTagId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Vocabulary: multiple choice
// ─────────────────────────────────────────────────────────────

model VocabExercise {
  id            String         @id @default(cuid())
  cefrLevel     CefrLevel
  source        ExerciseSource @default(CURATED)
  status        ContentStatus  @default(DRAFT)
  skillTagId    String?

  /// JSON payload validated by VocabContentSchema (packages/db/src/schemas/exercises/vocab.ts).
  /// Structure: { source: { targetLexeme, exampleSentence? }, localized: { ... }, choices, correctIndex }
  content       Json

  generatorMeta Json?
  createdById   String?
  reviewedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  skillTag    SkillTag?      @relation(fields: [skillTagId], references: [id])
  createdBy   User?          @relation("VocabCreatedBy", fields: [createdById], references: [id])
  reviewedBy  User?          @relation("VocabReviewedBy", fields: [reviewedById], references: [id])
  attempts    VocabAttempt[]

  @@index([cefrLevel, status])
  @@index([skillTagId])
  @@index([status])
}

model VocabAttempt {
  id            String   @id @default(cuid())
  userId        String
  exerciseId    String
  selectedIndex Int
  isCorrect     Boolean
  timeMs        Int?
  createdAt     DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise VocabExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([exerciseId])
}

// ─────────────────────────────────────────────────────────────
// Grammar: fill-in-the-blank
// ─────────────────────────────────────────────────────────────

model GrammarExercise {
  id            String         @id @default(cuid())
  cefrLevel     CefrLevel
  source        ExerciseSource @default(CURATED)
  status        ContentStatus  @default(DRAFT)
  skillTagId    String?

  /// JSON payload validated by GrammarContentSchema.
  /// Structure: { source: { template, acceptedAnswers }, localized: { instructions, hint?, explanation? } }
  content       Json

  generatorMeta Json?
  createdById   String?
  reviewedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  skillTag    SkillTag?        @relation(fields: [skillTagId], references: [id])
  createdBy   User?            @relation("GrammarCreatedBy", fields: [createdById], references: [id])
  reviewedBy  User?            @relation("GrammarReviewedBy", fields: [reviewedById], references: [id])
  attempts    GrammarAttempt[]

  @@index([cefrLevel, status])
  @@index([skillTagId])
  @@index([status])
}

model GrammarAttempt {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  userAnswer String
  isCorrect  Boolean
  timeMs     Int?
  createdAt  DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise GrammarExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([exerciseId])
}

// ─────────────────────────────────────────────────────────────
// Listening: transcription
// ─────────────────────────────────────────────────────────────

model ListeningExercise {
  id            String         @id @default(cuid())
  cefrLevel     CefrLevel
  source        ExerciseSource @default(CURATED)
  status        ContentStatus  @default(DRAFT)
  skillTagId    String?

  /// JSON payload validated by ListeningContentSchema.
  /// Structure: { source: { audioUrl, durationSec, transcript }, localized: { instructions, contextNote? }, questions: [...] }
  content       Json

  generatorMeta Json?
  createdById   String?
  reviewedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  skillTag    SkillTag?           @relation(fields: [skillTagId], references: [id])
  createdBy   User?               @relation("ListeningCreatedBy", fields: [createdById], references: [id])
  reviewedBy  User?               @relation("ListeningReviewedBy", fields: [reviewedById], references: [id])
  attempts    ListeningAttempt[]

  @@index([cefrLevel, status])
  @@index([skillTagId])
  @@index([status])
}

model ListeningAttempt {
  id         String   @id @default(cuid())
  userId     String
  exerciseId String
  userAnswer String   @db.Text
  similarity Float
  isCorrect  Boolean
  playCount  Int      @default(1)
  timeMs     Int?
  createdAt  DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise ListeningExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([exerciseId])
}

// ─────────────────────────────────────────────────────────────
// Diagnostic test (pseudo-CAT)
// ─────────────────────────────────────────────────────────────

enum DiagnosticKind {
  VOCAB
  GRAMMAR
  LISTENING
}

model DiagnosticItem {
  id            String         @id @default(cuid())
  cefrLevel     CefrLevel
  kind          DiagnosticKind
  source        ExerciseSource @default(CURATED)
  status        ContentStatus  @default(DRAFT)
  skillTagId    String?

  /// JSON payload validated by DiagnosticContentSchema.
  /// Structure: { source: { stem, choices, correctIndex }, localized?: { explanation? } }
  content       Json

  generatorMeta Json?
  createdById   String?
  reviewedById  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  skillTag    SkillTag?            @relation(fields: [skillTagId], references: [id])
  createdBy   User?                @relation("DiagnosticCreatedBy", fields: [createdById], references: [id])
  reviewedBy  User?                @relation("DiagnosticReviewedBy", fields: [reviewedById], references: [id])
  answers     DiagnosticAnswer[]

  @@index([cefrLevel, kind, status])
  @@index([status])
}

enum DiagnosticStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model DiagnosticAttempt {
  id          String           @id @default(cuid())
  userId      String
  status      DiagnosticStatus @default(IN_PROGRESS)
  startedAt   DateTime         @default(now())
  completedAt DateTime?

  // Pseudo-CAT state
  currentLevel       CefrLevel   @default(B1)
  consecutiveCorrect Int         @default(0)
  consecutiveWrong   Int         @default(0)
  itemsAnswered      Int         @default(0)
  levelTrajectory    CefrLevel[] @default([])

  assessedLevel CefrLevel?

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers DiagnosticAnswer[]

  @@index([userId])
  @@index([status, startedAt])
}

model DiagnosticAnswer {
  id         String    @id @default(cuid())
  attemptId  String
  itemId     String
  userAnswer String    @db.Text
  isCorrect  Boolean
  timeMs     Int?
  itemLevel  CefrLevel
  position   Int
  createdAt  DateTime  @default(now())

  attempt DiagnosticAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  item    DiagnosticItem    @relation(fields: [itemId], references: [id])

  @@unique([attemptId, position])
  @@index([attemptId])
}

// ============================================================================
// LEARNER MODEL — Layer 3: Knowledge Graph
// ============================================================================

enum ConceptCategory {
  GRAMMAR
  VOCAB
  LISTENING
  PHONETICS
  DISCOURSE
  PRAGMATICS
}

enum EdgeKind {
  PREREQUISITE
  RELATED
  CONTRASTS_WITH
  PART_OF
}

/// A learnable concept (grammar pattern, vocab cluster, listening sub-skill, ...).
/// IDs are human-readable, dotted, lowercase snake_case (e.g. "present_perfect.with_for_since").
/// Once assigned, a concept ID is immutable. To rename, introduce a ConceptAlias row (TBD).
model Concept {
  id          String          @id
  name        String
  description String?         @db.Text
  cefrLevel   CefrLevel
  category    ConceptCategory
  masteries ConceptMastery[]
  items Item[]

  outgoingEdges ConceptEdge[] @relation("ConceptOutgoing")
  incomingEdges ConceptEdge[] @relation("ConceptIncoming")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cefrLevel])
  @@index([category])
  @@index([cefrLevel, category])
}

/// A directed edge between concepts.
///
/// PREREQUISITE: from = prerequisite, to = dependent. Must form a DAG (enforced
///   by the @englishlearn/learner-model graph builder; not by the DB).
/// RELATED, CONTRASTS_WITH: treated as symmetric by traversal code.
/// PART_OF: from = part, to = whole.
model ConceptEdge {
  id     String   @id @default(cuid())
  fromId String
  toId   String
  kind   EdgeKind
  weight Float    @default(1.0)

  from Concept @relation("ConceptOutgoing", fields: [fromId], references: [id], onDelete: Cascade)
  to   Concept @relation("ConceptIncoming", fields: [toId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([fromId, toId, kind])
  @@index([fromId])
  @@index([toId])
  @@index([kind])
}
/// Per-user BKT+ snapshot for a single concept.
///
/// Source of truth on Day 7 will be LearnerEvent (append-only); this row
/// is then a materialized projection rebuilt by replay. Until then it is
/// updated directly by the LearnerService.
model ConceptMastery {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  conceptId String
  concept   Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  // BKT state — see packages/learner-model/src/core/bkt/types.ts
  pKnown          Float
  pLearn          Float
  pSlip           Float
  pGuess          Float
  pForgetLambda   Float

  /// Anchor for forgetting decay. Stored as ms epoch for parity with pure core.
  lastUpdatedAt   BigInt

  observationCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, conceptId])
  @@index([userId])
  @@index([conceptId])
}

/// An atomic, individually reviewable unit of knowledge.
///
/// Item ≠ Exercise: an Exercise is a delivery vehicle (a rendered question);
/// an Item is the underlying fact/pattern whose memory we track via FSRS.
/// One Item will typically be exercised by many Exercises (M:N link deferred
/// to Week 2 — see design decisions above).
///
/// Seed items use stable human-readable IDs ("item.<concept>.<slug>") so the
/// seed script can upsert idempotently. Runtime-created items get cuid().
model Item {
  id        String   @id @default(cuid())
  conceptId String
  concept   Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  kind      ItemKind
  cefrLevel CefrLevel
  status    ContentStatus  @default(DRAFT)
  source    ExerciseSource @default(CURATED)

  /// JSON payload validated by the per-kind schemas in
  /// packages/db/src/schemas/items/ (VocabWordContentSchema, etc).
  /// Structure: { source: {...}, localized: {...} }
  content   Json

  /// IRT 2PL parameters. Neutral defaults until calibration (needs ≥500
  /// outcomes per item). Used by predictCorrect in @englishlearn/learner-model.
  irtDiscrimination Float @default(1.0) // a
  irtDifficulty     Float @default(0.0) // b

  generatorMeta Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reviewStates ItemReviewState[]

  @@index([conceptId])
  @@index([kind, cefrLevel])
  @@index([status])
}

/// Per-user FSRS memory state for a single Item.
///
/// Like ConceptMastery, this is a snapshot that will become a materialized
/// projection of LearnerEvent once event sourcing lands (Day 7). Until then
/// the LearnerService updates it directly.
model ItemReviewState {
  id     String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // FSRS card state — see packages/learner-model/src/core/fsrs/types.ts
  stability     Float
  difficulty    Float
  reps          Int            @default(0)
  lapses        Int            @default(0)
  learningSteps Int            @default(0)
  cardStatus    FsrsCardStatus @default(NEW)

  /// When this card is next due. Unix ms (BigInt) for parity with pure core.
  dueAt        BigInt
  /// Last review moment. Null until first review. Unix ms.
  lastReviewAt BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, itemId])
  @@index([userId, dueAt])
  @@index([itemId])
}

enum LearnerEventType {
  ITEM_ATTEMPTED
}

/// Append-only learner event log — the source of truth for the learner model.
///
/// ConceptMastery and ItemReviewState are materialized projections of this
/// table; the replay job (learner-model/src/service/replay.ts) can rebuild
/// them from scratch for any user.
///
/// INVARIANTS:
///   - Rows are NEVER updated or deleted (except GDPR user erasure via the
///     User onDelete: Cascade).
///   - payload is validated by the per-type Zod schema in
///     @englishlearn/db/schemas (ItemAttemptedPayloadSchema) BEFORE insert.
///   - occurredAt is the single timestamp used for the event AND both
///     projection updates in the same recordOutcome call — bit-exact replay
///     depends on this.
model LearnerEvent {
  id     String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type LearnerEventType

  /// Moment the outcome happened. Unix ms (BigInt) for parity with pure cores.
  occurredAt BigInt

  /// Per-type payload; see @englishlearn/db/schemas/learner-events.ts.
  payload Json

  /// DB insert time (audit only; never used by the model).
  createdAt DateTime @default(now())

  @@index([userId, occurredAt])
  @@index([type])
}