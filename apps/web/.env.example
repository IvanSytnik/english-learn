# ─── Required ───────────────────────────────────────────────
# Neon Postgres connection string. Get yours at https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-something.eu-central-1.aws.neon.tech/englishlearn?sslmode=require"

# Auth.js v5 secret. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-strong-random-string"

# ─── Optional (set in production) ───────────────────────────
# AUTH_URL is auto-detected on Vercel; set manually for self-hosted.
# AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# AI providers (added in a later phase)
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
